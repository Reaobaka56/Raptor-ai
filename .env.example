# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_code_review?schema=public"

# GitHub App
GITHUB_APP_ID=your_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_TOKEN=optional_github_pat_for_authenticated_scans

# Gemini AI
GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-2.5-pro

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# Rate limiting (FastAPI uses *_SECONDS, Express uses *_MS)
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=900
RATE_LIMIT_SCAN_MAX=10
RATE_LIMIT_SCAN_WINDOW_SECONDS=3600
RATE_LIMIT_FIX_PR_MAX=5
RATE_LIMIT_FIX_PR_WINDOW_SECONDS=3600
RATE_LIMIT_DEBUG_MAX=20
RATE_LIMIT_DEBUG_WINDOW_SECONDS=3600
RATE_LIMIT_MEMORY_SEARCH_MAX=30
RATE_LIMIT_MEMORY_SEARCH_WINDOW_SECONDS=3600
RATE_LIMIT_ONBOARDING_MAX=30
RATE_LIMIT_ONBOARDING_WINDOW_SECONDS=3600
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=900
RATE_LIMIT_API_MAX=300
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_WEBHOOK_MAX=60
RATE_LIMIT_WEBHOOK_WINDOW_MS=3600000
RATE_LIMIT_GLOBAL_WINDOW_MS=900000

# Frontend OAuth callback override (must match GitHub OAuth/App callback URL)
VITE_GITHUB_REDIRECT_URI=https://raptor-agent.vercel.app/api/auth/github/callback
