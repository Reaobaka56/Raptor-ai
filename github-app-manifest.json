{
  "name": "Raptor AI Code Review",
  "url": "https://raptor-ai.onrender.com",
  "hook_attributes": {
    "url": "https://raptor-ai.onrender.com/api/webhook/github",
    "active": true
  },
  "redirect_url": "https://raptor-ai.onrender.com/api/auth/callback",
  "setup_url": "https://raptor-ai.onrender.com/dashboard",
  "setup_on_update": true,
  "default_permissions": {
    "pull_requests": "write",
    "contents": "write",
    "issues": "write",
    "metadata": "read"
  },
  "default_events": [
    "pull_request",
    "installation",
    "installation_repositories"
  ],
  "public": true
}
