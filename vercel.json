{
  "framework": "vite",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "build": "echo 'use vercel.json buildCommand'"
  "rewrites": [
    { "source": "/api/auth/github/callback", "destination": "/index.html" },
    { "source": "/api/(.*)", "destination": "https://raptor-ai.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
